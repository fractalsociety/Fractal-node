# Local Langfuse runtime.
# Run ./scripts/langfuse-local.sh init to create tools/codex-langfuse/.env
# with generated secrets.

LANGFUSE_PORT=3000
LANGFUSE_MINIO_PORT=9090
LANGFUSE_MINIO_CONSOLE_PORT=9091

DATABASE_URL=postgresql://langfuse:langfuse@langfuse-postgres:5432/langfuse
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=langfuse
POSTGRES_DB=langfuse

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-generated-secret
SALT=replace-with-generated-salt
ENCRYPTION_KEY=replace-with-64-hex-chars
TELEMETRY_ENABLED=false

CLICKHOUSE_MIGRATION_URL=clickhouse://clickhouse:clickhouse@langfuse-clickhouse:9000/langfuse
CLICKHOUSE_URL=http://langfuse-clickhouse:8123
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DB=langfuse
CLICKHOUSE_CLUSTER_ENABLED=false

REDIS_CONNECTION_STRING=redis://langfuse-redis:6379

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecret
LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_EVENT_UPLOAD_REGION=auto
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=miniosecret
LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=http://langfuse-minio:9000
LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=true

LANGFUSE_S3_MEDIA_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_MEDIA_UPLOAD_REGION=auto
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=miniosecret
LANGFUSE_S3_MEDIA_UPLOAD_ENDPOINT=http://langfuse-minio:9000
LANGFUSE_S3_MEDIA_UPLOAD_FORCE_PATH_STYLE=true

LANGFUSE_S3_BATCH_EXPORT_ENABLED=false

# Fill these after creating a Langfuse project and API key in the UI.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=replace-with-generated-langfuse-public-key
LANGFUSE_SECRET_KEY=replace-with-generated-langfuse-secret-key

# Headless local initialization.
# These let Langfuse create a local org, user, project, and API key on startup.
LANGFUSE_INIT_ORG_ID=fractal-local
LANGFUSE_INIT_ORG_NAME=Fractal Local
LANGFUSE_INIT_PROJECT_ID=codex-sessions
LANGFUSE_INIT_PROJECT_NAME=Codex Sessions
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=replace-with-generated-langfuse-public-key
LANGFUSE_INIT_PROJECT_SECRET_KEY=replace-with-generated-langfuse-secret-key
LANGFUSE_INIT_USER_EMAIL=hello@fractalsociety.org
LANGFUSE_INIT_USER_NAME=Fractal Society
LANGFUSE_INIT_USER_PASSWORD=replace-with-generated-local-password
